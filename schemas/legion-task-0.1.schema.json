{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://legion.local/schemas/legion-task-0.1.schema.json",
  "title": "LEGION Agent Task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "role",
    "objective",
    "inputs",
    "constraints",
    "outputs",
    "acceptance",
    "forbidden",
    "reviewer",
    "handoff",
    "decision"
  ],
  "properties": {
    "id": {"type": "string", "pattern": "^LEGION-[0-9]{4,}$"},
    "role": {"type": "string"},
    "objective": {"type": "string", "minLength": 1},
    "inputs": {"type": "array", "items": {"type": "string"}},
    "constraints": {"type": "array", "items": {"type": "string"}},
    "outputs": {"type": "array", "items": {"type": "string"}},
    "acceptance": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "forbidden": {"type": "array", "items": {"type": "string"}},
    "reviewer": {"type": "string", "minLength": 1},
    "handoff": {"type": "string", "minLength": 1},
    "decision": {"enum": ["Y", "N", "RESEARCH_ONLY"]},
    "claimsImpact": {"enum": ["NONE", "NARROWS", "STRENGTHENS_WITH_EVIDENCE", "REVIEW_REQUIRED"]},
    "securityImpact": {"type": "string"},
    "dueCondition": {"type": "string"}
  }
}
