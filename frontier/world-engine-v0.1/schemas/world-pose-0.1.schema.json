{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://world2.example/schemas/world-pose-0.1.schema.json",
  "title": "WorldEngine deterministic pose frame",
  "type": "object",
  "required": ["schema", "sequence", "tick", "timestamp_unix_ms", "source", "valid", "freshness_ms", "behavior", "features_q16", "pose", "frame_hash"],
  "properties": {
    "schema": {"const": "world.pose/0.1"},
    "sequence": {"type": "integer", "minimum": 0},
    "tick": {"type": "integer", "minimum": 0},
    "timestamp_unix_ms": {"type": "integer", "minimum": 0},
    "source": {"enum": ["SIMULATED", "RECORDED_REPLAY", "LIVE_WLAN", "STALE_WLAN"]},
    "valid": {"type": "boolean"},
    "freshness_ms": {"type": "integer", "minimum": 0},
    "behavior": {"enum": ["CALM", "ATTUNE", "STORM", "STALE"]},
    "features_q16": {
      "type": "object",
      "required": ["strength", "variability", "novelty"],
      "properties": {
        "strength": {"type": "integer", "minimum": 0, "maximum": 65535},
        "variability": {"type": "integer", "minimum": 0, "maximum": 65535},
        "novelty": {"type": "integer", "minimum": 0, "maximum": 65535}
      },
      "additionalProperties": false
    },
    "pose": {
      "type": "object",
      "required": ["root_y_um", "root_roll_mdeg", "neck1_pitch_mdeg", "neck2_pitch_mdeg", "head_yaw_mdeg", "wing_l_roll_mdeg", "wing_r_roll_mdeg", "tail1_yaw_mdeg", "tail2_yaw_mdeg", "tail3_yaw_mdeg"],
      "properties": {
        "root_y_um": {"type": "integer"},
        "root_roll_mdeg": {"type": "integer"},
        "neck1_pitch_mdeg": {"type": "integer"},
        "neck2_pitch_mdeg": {"type": "integer"},
        "head_yaw_mdeg": {"type": "integer"},
        "wing_l_roll_mdeg": {"type": "integer"},
        "wing_r_roll_mdeg": {"type": "integer"},
        "tail1_yaw_mdeg": {"type": "integer"},
        "tail2_yaw_mdeg": {"type": "integer"},
        "tail3_yaw_mdeg": {"type": "integer"}
      },
      "additionalProperties": false
    },
    "frame_hash": {"type": "string", "pattern": "^[0-9a-f]{16}$"}
  },
  "additionalProperties": false
}
